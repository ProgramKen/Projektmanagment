{
  "mcpServers": {
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "env": {
        "PUPPETEER_LAUNCH_OPTIONS": "{\"headless\": false, \"defaultViewport\": {\"width\": 1280, \"height\": 720}, \"args\": [\"--start-maximized\"]}",
        "ALLOW_DANGEROUS": "true"
      }
    }
  }
}
