rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Projects access rules
    match /projects/{projectId} {
      // Allow read if user is a team member
      allow read: if request.auth != null && 
        (request.auth.uid in resource.data.teamMembers.map(member => member.userId) ||
         request.auth.uid == resource.data.ownerId);
      
      // Allow create if user is authenticated
      allow create: if request.auth != null && 
        request.auth.uid == resource.data.ownerId &&
        validateProject(resource.data);
      
      // Allow update if user is owner or admin
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.ownerId ||
         isProjectAdmin(request.auth.uid, resource.data.teamMembers)) &&
        validateProject(request.resource.data);
      
      // Allow delete if user is owner
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.ownerId;
    }
    
    // Tasks access rules
    match /tasks/{taskId} {
      // Allow read if user has access to the project
      allow read: if request.auth != null && 
        canAccessProject(request.auth.uid, resource.data.projectId);
      
      // Allow create if user has access to the project
      allow create: if request.auth != null && 
        canAccessProject(request.auth.uid, resource.data.projectId) &&
        validateTask(resource.data);
      
      // Allow update if user has access to the project
      allow update: if request.auth != null && 
        canAccessProject(request.auth.uid, resource.data.projectId) &&
        validateTask(request.resource.data);
      
      // Allow delete if user has access to the project
      allow delete: if request.auth != null && 
        canAccessProject(request.auth.uid, resource.data.projectId);
    }
    
    // Files access rules
    match /files/{fileId} {
      // Allow read if user has access to the project
      allow read: if request.auth != null && 
        (resource.data.projectId == null || 
         canAccessProject(request.auth.uid, resource.data.projectId));
      
      // Allow create if user is authenticated
      allow create: if request.auth != null && 
        request.auth.uid == resource.data.uploadedBy &&
        validateFile(resource.data);
      
      // Allow update if user is the uploader
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.uploadedBy;
      
      // Allow delete if user is the uploader
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.uploadedBy;
    }
    
    // Chat messages access rules
    match /messages/{messageId} {
      // Allow read if user has access to the project
      allow read: if request.auth != null && 
        (resource.data.projectId == null || 
         canAccessProject(request.auth.uid, resource.data.projectId));
      
      // Allow create if user is authenticated
      allow create: if request.auth != null && 
        request.auth.uid == resource.data.authorId &&
        validateMessage(resource.data);
      
      // Allow update if user is the author (for editing)
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.authorId;
      
      // Allow delete if user is the author
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.authorId;
    }
    
    // Helper functions
    function validateProject(data) {
      return data.keys().hasAll(['name', 'description', 'status', 'priority', 'ownerId', 'teamMembers']) &&
             data.name is string && data.name.size() > 0 &&
             data.description is string &&
             data.status in ['planning', 'active', 'on-hold', 'completed', 'archived'] &&
             data.priority in ['low', 'medium', 'high', 'critical'] &&
             data.ownerId is string &&
             data.teamMembers is list;
    }
    
    function validateTask(data) {
      return data.keys().hasAll(['title', 'projectId', 'status', 'priority', 'reporterId']) &&
             data.title is string && data.title.size() > 0 &&
             data.projectId is string &&
             data.status in ['todo', 'in-progress', 'review', 'done'] &&
             data.priority in ['low', 'medium', 'high', 'critical'] &&
             data.reporterId is string;
    }
    
    function validateFile(data) {
      return data.keys().hasAll(['name', 'type', 'size', 'uploadedBy']) &&
             data.name is string && data.name.size() > 0 &&
             data.type is string &&
             data.size is number && data.size > 0 &&
             data.uploadedBy is string;
    }
    
    function validateMessage(data) {
      return data.keys().hasAll(['content', 'authorId', 'type']) &&
             data.content is string && data.content.size() > 0 &&
             data.authorId is string &&
             data.type in ['text', 'file', 'system'];
    }
    
    function isProjectAdmin(userId, teamMembers) {
      return teamMembers.filter(member => 
        member.userId == userId && 
        member.role in ['owner', 'admin']
      ).size() > 0;
    }
    
    function canAccessProject(userId, projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)) &&
             (userId in get(/databases/$(database)/documents/projects/$(projectId)).data.teamMembers.map(member => member.userId) ||
              userId == get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId);
    }
  }
}